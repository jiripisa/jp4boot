#!/bin/bash
# Bootstrap a new macOS SwiftUI app from template
# Usage: jp4boot AppName [--bundle-id com.example]
#        Creates ./AppName/ with complete project structure

set -e

# --- Parse arguments ---
APP_NAME=""
BUNDLE_PREFIX=""
NOTARY_PROFILE=""

while [ $# -gt 0 ]; do
    case "$1" in
        --bundle-id) BUNDLE_PREFIX="$2"; shift 2 ;;
        --notary-profile) NOTARY_PROFILE="$2"; shift 2 ;;
        -*) echo "Unknown option: $1"; exit 1 ;;
        *) APP_NAME="$1"; shift ;;
    esac
done

if [ -z "$APP_NAME" ]; then
    echo "Usage: $0 AppName [options]"
    echo "Creates ./AppName/ with complete project structure"
    echo ""
    echo "Options:"
    echo "  --bundle-id PREFIX        Bundle ID prefix (default: com.example)"
    echo "                            Result: PREFIX.appname"
    echo "  --notary-profile NAME     Keychain profile for notarization"
    echo "                            (default: notary)"
    exit 1
fi

APP_NAME_LOWER=$(echo "$APP_NAME" | tr '[:upper:]' '[:lower:]')
BUNDLE_PREFIX="${BUNDLE_PREFIX:-com.example}"
BUNDLE_ID="${BUNDLE_PREFIX}.${APP_NAME_LOWER}"
NOTARY_PROFILE="${NOTARY_PROFILE:-notary}"
YEAR=$(date +%Y)

SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlinks to find the real location
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
TEMPLATE_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/templates"
TARGET_DIR="$(pwd)/$APP_NAME"

if [ -d "$TARGET_DIR" ]; then
    echo "ERROR: $TARGET_DIR already exists."
    exit 1
fi

# --- Create directory structure ---
mkdir -p "$TARGET_DIR/Sources/$APP_NAME/App"
mkdir -p "$TARGET_DIR/Sources/$APP_NAME/Models"
mkdir -p "$TARGET_DIR/Sources/$APP_NAME/Services"
mkdir -p "$TARGET_DIR/Sources/$APP_NAME/Views/Components"
mkdir -p "$TARGET_DIR/Sources/$APP_NAME/Views/Theme"
mkdir -p "$TARGET_DIR/Resources"
mkdir -p "$TARGET_DIR/Tests/${APP_NAME}Tests"

# --- Helper: copy template with placeholder replacement ---
apply_template() {
    local src="$1"
    local dst="$2"
    sed -e "s/__APP_NAME__/$APP_NAME/g" \
        -e "s/__BUNDLE_ID__/$BUNDLE_ID/g" \
        -e "s/__NOTARY_PROFILE__/$NOTARY_PROFILE/g" \
        -e "s/__YEAR__/$YEAR/g" \
        "$src" > "$dst"
}

# --- Copy and transform templates ---
apply_template "$TEMPLATE_DIR/Package.swift.template"     "$TARGET_DIR/Package.swift"
apply_template "$TEMPLATE_DIR/build.sh.template"          "$TARGET_DIR/build.sh"
apply_template "$TEMPLATE_DIR/run.sh.template"            "$TARGET_DIR/run.sh"
apply_template "$TEMPLATE_DIR/CLAUDE.md.template"         "$TARGET_DIR/CLAUDE.md"
apply_template "$TEMPLATE_DIR/Info.plist.template"        "$TARGET_DIR/Resources/Info.plist"
apply_template "$TEMPLATE_DIR/Entitlements.template"      "$TARGET_DIR/Resources/$APP_NAME.entitlements"
apply_template "$TEMPLATE_DIR/gitignore.template"         "$TARGET_DIR/.gitignore"
apply_template "$TEMPLATE_DIR/AppApp.swift.template"      "$TARGET_DIR/Sources/$APP_NAME/App/${APP_NAME}App.swift"
apply_template "$TEMPLATE_DIR/ContentView.swift.template" "$TARGET_DIR/Sources/$APP_NAME/Views/ContentView.swift"
apply_template "$TEMPLATE_DIR/Tests.swift.template"       "$TARGET_DIR/Tests/${APP_NAME}Tests/${APP_NAME}Tests.swift"

# Make scripts executable
chmod +x "$TARGET_DIR/build.sh"
chmod +x "$TARGET_DIR/run.sh"

# --- Init git repo ---
cd "$TARGET_DIR"
git init -q
git add -A
git commit -q -m "Initial project structure from template"

# --- Print manual ---
cat <<MANUAL

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  $APP_NAME — project created successfully
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  Location:    $TARGET_DIR
  Bundle ID:   $BUNDLE_ID
  Tech:        Swift 6.0 / SwiftUI / macOS 15+

  Generated structure:

  $APP_NAME/
  ├── Package.swift              SPM package definition
  ├── build.sh                   Build script (debug/release/dist)
  ├── run.sh                     Run script (debug/release)
  ├── CLAUDE.md                  Conventions for Claude Code
  ├── Sources/$APP_NAME/
  │   ├── App/${APP_NAME}App.swift    @main entry point
  │   ├── Models/                     Data models
  │   ├── Services/                   Business logic
  │   └── Views/
  │       ├── ContentView.swift       Main view
  │       ├── Components/             Reusable components
  │       └── Theme/                  Colors, fonts, styles
  ├── Resources/
  │   ├── Info.plist                  Bundle metadata
  │   └── ${APP_NAME}.entitlements    App entitlements
  └── Tests/${APP_NAME}Tests/         Unit tests

  Commands:

  cd $TARGET_DIR

  ./run.sh                Debug build + run in terminal (logs visible)
  ./run.sh release        Release build + open .app

  ./build.sh              Debug build (default)
  ./build.sh release      Optimized release build
  ./build.sh dist         Release + code sign + notarize + DMG
  ./build.sh clean        Remove all build artifacts

  Next steps:

  1. Add your app icon as Resources/AppIcon.png (1024x1024)
  2. Edit Sources/$APP_NAME/Views/ContentView.swift
  3. Run with ./run.sh

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

MANUAL
